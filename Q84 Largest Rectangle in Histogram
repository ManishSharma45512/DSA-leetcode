///I took help of gemini to improve time complexity from O(n^2) to O(n) 
class Solution {
public:
    int largestRectangleArea(vector<int>& heights) {
        if (heights.empty()) return 0;
        
        int n = heights.size();
        vector<int> lessFromLeft(n);
        vector<int> lessFromRight(n);
        
        lessFromLeft[0] = -1;
        lessFromRight[n - 1] = n;
        
        // 1. Find the first smaller bar on the left
        for (int i = 1; i < n; i++) {
            int dis = i - 1;
            while (dis >= 0 && heights[dis] >= heights[i]) {
                dis = lessFromLeft[dis];
            }
            lessFromLeft[i] = dis;
        }
        
        // 2. Find the first smaller bar on the right
        for (int i = n - 2; i >= 0; i--) {
            int dis = i + 1;
            while (dis < n && heights[dis] >= heights[i]) {
                dis = lessFromRight[dis];
            }
            lessFromRight[i] = dis;
        }
        
        int area = 0;
        
        // 3. Compute maximum area in a final single pass
        for (int i = 0; i < n; i++) {
            int width = lessFromRight[i] - lessFromLeft[i] - 1;
            area = max(area, heights[i] * width);
        }
        
        return area;
    }
};
