class Solution {
public:
    ListNode* deleteDuplicates(ListNode* head) {
        if (head == nullptr) return head;

        unordered_map<int, int> freq;
        ListNode* temp = head;

        
        while (temp != nullptr) {
            freq[temp->val]++;
            temp = temp->next;
        }

        
        ListNode* dummy = new ListNode(0);
        ListNode* current = dummy;
        
        temp = head; 
        while (temp != nullptr) {
            if (freq[temp->val] == 1) {
                current->next = new ListNode(temp->val);
                current = current->next;
            }
            temp = temp->next;
        }

        ListNode* actualHead = dummy->next;
        delete dummy; // Clean up the dummy node memory
        return actualHead;
    }
};
