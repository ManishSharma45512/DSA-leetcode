class Solution {
private:
    
    bool helper(vector<int>& nums, int target, int st, int end) {
        if (st > end) return false;

        int mid = st + (end - st) / 2;
        if (nums[mid] == target) return true;

     
        return helper(nums, target, st, mid - 1) || helper(nums, target, mid + 1, end);
    }

public:
    bool search(vector<int>& nums, int target) {
        if (nums.empty()) return false;
        return helper(nums, target, 0, nums.size() - 1);
    }
};
