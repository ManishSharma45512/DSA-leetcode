class Solution {
public:
    ListNode* middleNode(ListNode* head) {
        if(head==nullptr) return head;

        int index=0;
        ListNode* temp=head;

        
        while(temp!=nullptr){
            index++;
            temp=temp->next;
        }

        int middle=index/2;
        int curr=0;

        temp=head;
        while(temp!=0 && middle!=curr){
            curr++;
            temp=temp->next;
        }

        return temp;
        
    }
};
