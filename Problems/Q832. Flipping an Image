class Solution {
public:
    vector<vector<int>> flipAndInvertImage(vector<vector<int>>& image) {
        
        vector<vector<int>> result = image;

        int n = image.size();
        int m = image[0].size();

        for (int i = 0; i < n; i++) {
            
            
            for (int j = 0; j <= (m - 1) / 2; j++) {
                
                
                int l = m - j - 1; 

                
                
                int leftVal = image[i][j];
                int rightVal = image[i][l];

                result[i][l] = !leftVal;  
                result[i][j] = !rightVal; 
            }
        }

        return result;
    }
};
