class Solution {
public:
    int numTrees(int n) {

        vector<int> dp(n + 1, 0);
        
        // Base cases
        dp[0] = 1; // 0 nodes means 1 empty tree layout
        dp[1] = 1; // 1 node means 1 layout
        
        // Loop to calculate combinations for 2 nodes, then 3 nodes, all the way to n nodes
        for (int totalNodes = 2; totalNodes <= n; totalNodes++) {
            for (int root = 1; root <= totalNodes; root++) {
                int leftNodes = root - 1;
                int rightNodes = totalNodes - root;
                
                // Total combinations = left choices * right choices
                dp[totalNodes] += dp[leftNodes] * dp[rightNodes];
            }
        }
        
        return dp[n];
    }
};
